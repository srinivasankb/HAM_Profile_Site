---
import { Search as SearchIcon, FileText, Book, Info, Hash, Command, X } from 'lucide-react';

interface SearchItem {
  title: string;
  url: string;
  type: 'blog' | 'resource' | 'page';
  description?: string;
}

interface Props {
  items: SearchItem[];
}

const { items } = Astro.props;
---

<div id="search-modal" class="search-overlay" style="display: none;">
  <div class="search-box modern-card" role="combobox" aria-expanded="false" aria-haspopup="listbox" aria-owns="search-results">
    <div class="search-input-wrapper">
      <SearchIcon size={20} class="search-icon-dim" />
      <input 
        type="text" 
        id="search-input" 
        placeholder="Search everything... (Cmd+K)" 
        autocomplete="off"
      />
      <button id="close-search" class="close-search-btn">
        <X size={18} />
      </button>
    </div>

    <div id="search-results-container" class="search-results-viewport">
      <div id="search-results" class="search-results-list" role="listbox">
        <!-- Results will be injected here -->
      </div>
      <div id="search-empty" class="search-empty-state" style="display: none;">
        <Info size={32} stroke-width={1} />
        <p>No results found for your search.</p>
      </div>
    </div>

    <footer class="search-footer">
      <div class="search-hint">
        <span class="key-cap">↑↓</span> Navigate
      </div>
      <div class="search-hint">
        <span class="key-cap">Enter</span> Select
      </div>
      <div class="search-hint">
        <span class="key-cap">Esc</span> Close
      </div>
    </footer>
  </div>
</div>

<script define:vars={{ items }}>
  const modal = document.getElementById('search-modal');
  const input = document.getElementById('search-input');
  const resultsList = document.getElementById('search-results');
  const emptyState = document.getElementById('search-empty');
  const closeBtn = document.getElementById('close-search');
  
  let selectedIndex = -1;
  let currentResults = [];

  function openSearch() {
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
    input.focus();
    selectedIndex = -1;
    renderResults(items); // Show all by default or popular? Let's show first few.
  }

  function closeSearch() {
    modal.style.display = 'none';
    document.body.style.overflow = '';
    input.value = '';
  }

  function renderResults(results) {
    currentResults = results;
    resultsList.innerHTML = '';
    
    if (results.length === 0) {
      emptyState.style.display = 'flex';
      return;
    }
    
    emptyState.style.display = 'none';
    
    results.forEach((item, index) => {
      const div = document.createElement('div');
      div.className = `search-item ${index === selectedIndex ? 'selected' : ''}`;
      div.id = `result-${index}`;
      div.role = 'option';
      
      const icon = item.type === 'blog' ? 'Book' : (item.type === 'resource' ? 'FileText' : 'Hash');
      
      div.innerHTML = `
        <div class="result-icon-wrap ${item.type}">
          ${getIconSvg(item.type)}
        </div>
        <div class="result-content">
          <div class="result-title">${item.title}</div>
          <div class="result-path">${item.url}</div>
        </div>
        <div class="result-type-tag">${item.type}</div>
      `;
      
      div.addEventListener('click', () => {
        window.location.href = item.url;
      });
      
      resultsList.appendChild(div);
    });
  }

  function getIconSvg(type) {
    if (type === 'blog') return '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-book-text"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"/><path d="M8 7h8"/><path d="M8 11h8"/><path d="M8 15h5"/></svg>';
    if (type === 'resource') return '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-library"><path d="m16 6 4 14"/><path d="M12 6v14"/><path d="M8 8v12"/><path d="M4 4v16"/><path d="M2 19h20"/></svg>';
    return '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-hash"><line x1="4" x2="20" y1="9" y2="9"/><line x1="4" x2="20" y1="15" y2="15"/><line x1="10" x2="8" y1="3" y2="21"/><line x1="16" x2="14" y1="3" y2="21"/></svg>';
  }

  input.addEventListener('input', (e) => {
    const query = e.target.value.toLowerCase();
    const filtered = items.filter(item => 
      item.title.toLowerCase().includes(query) || 
      (item.description && item.description.toLowerCase().includes(query)) ||
      item.type.toLowerCase().includes(query)
    );
    selectedIndex = filtered.length > 0 ? 0 : -1;
    renderResults(filtered);
  });

  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      openSearch();
    }
    
    if (e.key === 'Escape') {
      closeSearch();
    }
    
    if (modal.style.display === 'flex') {
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        selectedIndex = Math.min(selectedIndex + 1, currentResults.length - 1);
        updateSelection();
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        selectedIndex = Math.max(selectedIndex - 1, 0);
        updateSelection();
      } else if (e.key === 'Enter' && selectedIndex >= 0) {
        window.location.href = currentResults[selectedIndex].url;
      }
    }
  });

  function updateSelection() {
    const items = resultsList.querySelectorAll('.search-item');
    items.forEach((item, index) => {
      if (index === selectedIndex) {
        item.classList.add('selected');
        item.scrollIntoView({ block: 'nearest' });
      } else {
        item.classList.remove('selected');
      }
    });
  }

  function initSearch() {
    selectedIndex = -1;
    // Set global access
    window.openSpotlight = openSearch;
    
    // Explicit close for modal click or btn
    closeBtn.addEventListener('click', closeSearch);
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeSearch();
    });

    // Handle trigger clicks
    document.querySelectorAll('.search-trigger, .mobile-search-btn').forEach(btn => {
      btn.addEventListener('click', openSearch);
    });
  }

  // Initialize on first load AND every view transition swap
  document.addEventListener('astro:page-load', initSearch);
</script>

<style is:global>
  .search-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(12px);
    z-index: 2000;
    display: flex;
    justify-content: center;
    padding-top: 10vh;
  }

  @media (max-width: 640px) {
    .search-overlay {
      padding-top: 0;
    }
  }

  .search-box {
    width: 90%;
    max-width: 600px;
    height: fit-content;
    max-height: 70vh;
    background: var(--card);
    border: 1px solid var(--border);
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    animation: slideUp 0.15s ease-out;
  }

  @media (max-width: 640px) {
    .search-box {
      width: 100%;
      height: 100%;
      max-height: 100vh;
      border: none;
      border-radius: 0;
    }
  }

  @keyframes slideUp {
    from { transform: translateY(20px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  .search-input-wrapper {
    display: flex;
    align-items: center;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid var(--border);
    gap: 1rem;
    background: var(--background);
  }

  .search-icon-dim {
    color: var(--muted-foreground);
  }

  #search-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    font-size: 1.1rem;
    color: var(--foreground);
    font-family: inherit;
  }

  .close-search-btn {
    background: var(--secondary);
    border: 1px solid var(--border);
    color: var(--muted-foreground);
    padding: 0.25rem;
    border-radius: 6px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .search-results-viewport {
    flex: 1;
    overflow-y: auto;
    padding: 0.5rem;
  }

  .search-results-list {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .search-item {
    display: flex;
    align-items: center;
    padding: 0.75rem 1rem;
    border-radius: 8px;
    gap: 1rem;
    cursor: pointer;
    transition: all 0.1s;
    border-left: 3px solid transparent;
    margin: 0 0.5rem;
  }

  .search-item.selected,
  .search-item:hover {
    background: var(--secondary);
    border-left-color: var(--primary);
  }

  .search-item.selected .result-title,
  .search-item:hover .result-title {
    color: var(--primary);
  }

  .result-icon-wrap {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--secondary);
    color: var(--muted-foreground);
    transition: all 0.1s;
  }

  .search-item.selected .result-icon-wrap,
  .search-item:hover .result-icon-wrap {
    background: var(--primary);
    color: var(--primary-foreground);
  }

  .result-content {
    flex: 1;
    min-width: 0;
  }

  .result-title {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--foreground);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .result-path {
    font-size: 0.75rem;
    color: var(--muted-foreground);
  }

  .result-type-tag {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--muted-foreground);
    padding: 0.2rem 0.5rem;
    background: var(--secondary);
    border-radius: 4px;
  }

  .search-footer {
    padding: 0.75rem 1.5rem;
    background: var(--secondary);
    border-top: 1px solid var(--border);
    display: flex;
    gap: 1.5rem;
  }

  @media (max-width: 640px) {
    .search-footer {
      display: none;
    }
  }

  .search-hint {
    font-size: 0.75rem;
    color: var(--muted-foreground);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .key-cap {
    background: var(--background);
    border: 1px solid var(--border);
    padding: 0.1rem 0.35rem;
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--foreground);
    min-width: 1.5rem;
    text-align: center;
  }

  .search-empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
    color: var(--muted-foreground);
    gap: 1rem;
    text-align: center;
  }
</style>
