---
import { Rss, Radio, MapPin, BookText, Compass, Menu, Home, Library } from 'lucide-react';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import profileData from '../data/profile.json';
import navData from '../data/navigation.json';

const IconMap: Record<string, any> = { Home, MapPin, BookText, Library, Compass, RSS: Rss, Radio };

interface Props {
	title: string;
	description?: string;
	image?: string;
	article?: boolean;
}

const { 
  title, 
  description = profileData.description, 
  image = profileData.images.profile,
  article = false
} = Astro.props;

const siteUrl = Astro.url.origin;
const currentUrl = Astro.url.href;
const pathname = Astro.url.pathname;
const ogImage = image.startsWith('http') ? image : `${siteUrl}${image}`;

// We'll need the blog data for the sidebar
import { getCollection } from 'astro:content';
const blogs = (await getCollection('blogs'))
  .filter(blog => !blog.data.unlisted)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const recentBlogs = blogs.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="manifest" href="/manifest.json" />
		<meta name="generator" content={Astro.generator} />
		
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">

		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content={article ? "article" : "website"} />
		<meta property="og:url" content={currentUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={currentUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:site" content={`@${profileData.social.twitter}`} />
    <meta name="twitter:creator" content={`@${profileData.social.twitter}`} />
    
    <ClientRouter />

    <!-- RSS Discovery -->
    <link rel="alternate" type="application/rss+xml" title={`${profileData.callsign} Radio Journal RSS Feed`} href="/blog/rss.xml" />
    <meta name="theme-color" content="#18181b" />

    <!-- Analytics -->
    <script is:inline defer data-domain={profileData.analytics.domain} src={profileData.analytics.scriptUrl}></script>
    <script is:inline>window.plausible = window.plausible || function() { (window.plausible.q = window.plausible.q || []).push(arguments) }</script>

    <!-- SEO Enhancements -->
    <link rel="canonical" href={currentUrl} />
    
    <!-- JSON-LD / Structured Data -->
    <script type="application/ld+json" is:inline define:vars={{ profileData }}>
      {
        "@context": "https://schema.org",
        "@type": "ProfilePage",
        "description": `Amateur Radio Operator Station ${profileData.callsign} - Technical explorer and QRP enthusiast.`,
        "name": `${profileData.callsign} Station`,
        "url": "https://ham.srinikb.in",
        "mainEntity": {
          "@type": "Person",
          "name": profileData.name,
          "alternateName": profileData.callsign,
          "description": "HAM Radio Operator, QRP Enthusiast and Technical Explorer",
          "jobTitle": profileData.seo.jobTitle,
          "sameAs": [
            `https://www.qrz.com/db/${profileData.callsign}`,
            `https://twitter.com/${profileData.social.twitter}`,
            `https://github.com/${profileData.social.github}`
          ],
          "contactPoint": {
            "@type": "ContactPoint",
            "email": profileData.contact.email,
            "contactType": "technical support"
          }
        },
        "knowsAbout": profileData.seo.keywords
      }
    </script>
	</head>
	<body>
    <div id="app-root" class="app-layout">
      <!-- Ported from App.jsx App Shell -->
      <script>
        // Check local storage for preferences on boot
        const theme = localStorage.getItem('theme') || 'light';
        document.documentElement.setAttribute('data-theme', theme);
      </script>

        <script>
          const initLayout = () => {
            const toggleMobile = () => {
              const overlay = document.querySelector('.mobile-menu-overlay');
              overlay?.classList.toggle('open');
            };

            document.querySelector('.burger-btn')?.addEventListener('click', toggleMobile);
            
            // Close mobile menu on nav
            document.querySelectorAll('.mobile-nav-item, .mobile-recent-item').forEach(link => {
              link.addEventListener('click', () => {
                document.querySelector('.mobile-menu-overlay')?.classList.remove('open');
              });
            });
          };

          // Run on initial load and every navigation
          document.addEventListener('astro:page-load', initLayout);
        </script>

        <!-- Desktop Top Nav -->
        <header class="desktop-nav">
          <div class="nav-container">
            <a href="/" class="nav-logo" transition:name="site-logo" data-astro-prefetch>
              <Radio size={24} /> <span class="logo-text">{profileData.callsign}</span>
            </a>
            
            <nav class="nav-links">
              {navData.map(item => {
                const Icon = IconMap[item.icon];
                return (
                  <a href={item.path} class={`nav-item ${pathname === item.path || (item.path !== '/' && pathname.startsWith(item.path)) ? 'active' : ''}`} data-astro-prefetch>
                    {Icon && <Icon size={18} />} {item.name}
                  </a>
                );
              })}
            </nav>

            <div class="nav-actions">
               <a href={`mailto:${profileData.contact.email}`} class="contact-btn">Get in touch</a>
            </div>
          </div>
        </header>

        <!-- Mobile Header -->
        <header class="mobile-header">
          <a href="/" class="mobile-logo" style="text-decoration: none; color: inherit;">
            <Radio size={20} /> {profileData.callsign}
          </a>
          <div class="mobile-header-actions">
            <button class="burger-btn">
              <Menu size={24} />
            </button>
          </div>
        </header>

        <!-- Mobile Menu Overlay -->
        <div class="mobile-menu-overlay">
            <div class="mobile-menu-section">
              <div class="sidebar-heading">Navigation</div>
              {navData.map(item => {
                const Icon = IconMap[item.icon];
                return (
                  <a href={item.path} class={`mobile-nav-item ${pathname === item.path || (item.path !== '/' && pathname.startsWith(item.path)) ? 'active' : ''}`}>
                    {Icon && <Icon size={20} />} {item.name}
                  </a>
                );
              })}
              <a href="/blog/rss.xml" class="mobile-nav-item">
                <Rss size={20} /> RSS Feed
              </a>
            </div>

          <div class="sidebar-footer" style="margin-top: auto;">
             <div class="footer-contact">
                <div class="card-label" style="font-size: 0.65rem; margin-bottom: 0.25rem;">Contact</div>
                <a href={`mailto:${profileData.contact.email}`} class="footer-link">{profileData.contact.email}</a>
              </div>
              <div class="footer-status-row">
                <span class="status-dot"></span>
                STATION QRV
              </div>
              <p class="footer-sig-text">73 de {profileData.callsign} • {profileData.location.split(',')[0]}</p>
          </div>
        </div>

        <main class="app-content">
          <slot />
        </main>

        <footer class="desktop-footer">
          <div class="footer-container">
            <div class="footer-info">
               <Radio size={20} /> <span class="logo-text">{profileData.callsign}</span>
                <p class="footer-desc" data-astro-prefetch>{profileData.subtitle}</p>
            </div>
            <div class="footer-links-grid">
              <div class="footer-group">
                <h4>Explore</h4>
                {navData.map(item => (
                  <a href={item.path} data-astro-prefetch>{item.name}</a>
                ))}
              </div>
              <div class="footer-group">
                <h4>Connect</h4>
                <a href={`mailto:${profileData.contact.email}`}>Email</a>
                <a href="/blog/rss.xml">RSS Feed</a>
              </div>
            </div>
          </div>
          <div class="footer-bottom">
            <p>73 de {profileData.callsign} • {profileData.location} • <a href={profileData.social.professional} target="_blank" style="color: inherit; text-decoration: none; opacity: 0.6;">Professional Profile</a></p>
          </div>
        </footer>

    </div>
	</body>
</html>
<style is:global>
  .app-layout {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }
</style>
